# ─── Django ───────────────────────────────────────────────────────────────────

# REQUIRED — generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hosts (use * for development only)
ALLOWED_HOSTS=*

# Base URL used in Wagtail admin emails
WAGTAILADMIN_BASE_URL=http://localhost:8000

# ─── AI (Mistral) ─────────────────────────────────────────────────────────────

# REQUIRED — get your key at https://console.mistral.ai/
MISTRAL_API_KEY=

# ─── Database (production only — SQLite is used in development) ───────────────

# DB_NAME=cdf
# DB_USER=cdf_user
# DB_PASSWORD=
